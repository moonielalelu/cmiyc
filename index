<!doctype html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
<title>One Click.</title>
<meta name="description" content="Just one click. That's it." />
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=Inter:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root{
    --bg:#F5F5F1;
    --ink:#121210;
    --muted:#8C8C86;
    --line:#DEDED6;
    --trap:#DFFA2F;
    --trap-ink:#1B1D07;
    --bad:#E8437A;
    --ease: cubic-bezier(.16,1,.3,1);
  }
  *{ box-sizing:border-box; -webkit-tap-highlight-color:transparent; }
  html,body{ height:100%; margin:0; overscroll-behavior:none; }
  body{
    background:var(--bg); color:var(--ink);
    font-family:'Inter', sans-serif;
    overflow:hidden; -webkit-font-smoothing:antialiased;
    touch-action:manipulation;
  }
  .stage{
    position:relative; width:100%; height:100dvh;
    display:flex; flex-direction:column; align-items:center; justify-content:center;
    padding:8vh 6vw; transition:background .5s var(--ease), color .5s var(--ease);
  }
  .stage.won{ background:var(--ink); color:var(--bg); }

  .screen{ display:none; text-align:center; width:100%; max-width:520px; }
  .screen.active{ display:flex; flex-direction:column; align-items:center; }

  .eyebrow{
    font-family:'IBM Plex Mono', monospace; font-size:11px; letter-spacing:0.08em;
    color:var(--muted); text-transform:uppercase; margin-bottom:14px;
  }

  h1{
    font-family:'Space Grotesk', sans-serif; font-weight:500;
    font-size:clamp(24px, 4.2vw, 40px); letter-spacing:-0.02em; margin:0 0 10px;
  }
  .sub{ font-size:14.5px; color:var(--muted); margin:0 0 6vh; max-width:380px; line-height:1.5; }

  /* --- Stage 1: dodging button --- */
  .zone{ position:relative; width:min(560px, 84vw); height:30vh; min-height:170px; }
  #btn{
    position:absolute; top:50%; left:50%; transform:translate(-50%,-50%);
    padding:18px 34px; font-family:'Inter', sans-serif; font-weight:600; font-size:16px;
    color:var(--ink); background:#fff; border:1.5px solid var(--ink); border-radius:100px;
    cursor:pointer; user-select:none;
    transition:background .18s, border-color .18s, left .38s var(--ease), top .38s var(--ease);
  }
  #btn:focus-visible{ outline:2px solid var(--trap); outline-offset:3px; }
  #btn.armed{ background:var(--trap); border-color:var(--trap-ink); }

  /* --- generic primary button --- */
  .primary{
    padding:16px 32px; font-family:'Inter', sans-serif; font-weight:600; font-size:15.5px;
    color:var(--ink); background:#fff; border:1.5px solid var(--ink); border-radius:100px;
    cursor:pointer; transition:background .15s, transform .15s;
  }
  .primary:active{ transform:scale(.97); }
  .primary:disabled{ opacity:.35; cursor:not-allowed; }
  .primary.hot{ background:var(--trap); border-color:var(--trap-ink); }

  /* --- Stage 2: robot checkbox --- */
  .check-row{
    display:flex; align-items:center; gap:12px; border:1.5px solid var(--ink);
    border-radius:14px; padding:16px 20px; background:#fff; cursor:pointer; user-select:none;
  }
  .check-row input{ width:20px; height:20px; accent-color:var(--trap-ink); cursor:pointer; }
  .check-row span{ font-size:14.5px; font-weight:500; }
  .fail-toast{
    margin-top:16px; font-family:'IBM Plex Mono', monospace; font-size:12.5px;
    color:var(--bad); min-height:18px;
  }

  /* --- Stage 3: slider --- */
  .slider-wrap{ width:min(420px, 80vw); }
  input[type="range"]{
    width:100%; -webkit-appearance:none; height:6px; border-radius:4px;
    background:var(--line); outline:none; margin:26px 0 4px;
  }
  input[type="range"]::-webkit-slider-thumb{
    -webkit-appearance:none; width:26px; height:26px; border-radius:50%;
    background:var(--ink); border:3px solid var(--trap); cursor:grab;
  }
  input[type="range"]::-moz-range-thumb{
    width:20px; height:20px; border-radius:50%; background:var(--ink); border:3px solid var(--trap); cursor:grab;
  }
  .slider-labels{ display:flex; justify-content:space-between; font-family:'IBM Plex Mono', monospace; font-size:11px; color:var(--muted); }

  /* --- Stage 4: loading --- */
  .bar-track{ width:min(420px, 80vw); height:10px; border-radius:6px; background:var(--line); overflow:hidden; margin:8px 0 14px; }
  .bar-fill{ height:100%; width:0%; background:var(--trap); border-radius:6px; transition:width .5s var(--ease); }
  .bar-pct{ font-family:'IBM Plex Mono', monospace; font-size:12px; color:var(--muted); }

  /* --- Stage 5: terms --- */
  .terms-box{
    width:min(460px, 84vw); max-height:26vh; overflow-y:auto; text-align:left;
    border:1.5px solid var(--ink); border-radius:14px; padding:18px 20px; background:#fff;
    font-size:13px; line-height:1.7; color:#333;
  }
  .terms-box p{ margin:0 0 10px; }
  .terms-check{ display:flex; align-items:center; gap:10px; margin:20px 0 6px; font-size:13px; }
  .terms-check input{ width:18px; height:18px; accent-color:var(--trap-ink); }

  /* narrator strip */
  .narrator{
    position:absolute; bottom:5vh; left:0; right:0; display:flex; justify-content:center; padding:0 6vw;
  }
  .narrator span{
    font-family:'IBM Plex Mono', monospace; font-size:11.5px; color:var(--muted); text-align:center;
    max-width:440px; letter-spacing:0.01em;
  }
  .stage.won .narrator span{ color:#8C8C7A; }

  /* win screen */
  .stage.won .screen:not(#s-win){ display:none !important; }
  #s-win h2{
    font-family:'Space Grotesk', sans-serif; font-weight:500; font-size:clamp(28px,5vw,46px);
    color:var(--trap); margin:0 0 14px;
  }
  #s-win p.lead{ font-size:14.5px; color:#B9B9AB; line-height:1.6; margin:0 0 26px; max-width:400px; }
  .trophy{
    width:100%; border:1px solid #33332B; border-radius:16px; padding:18px 20px; margin-bottom:22px;
    text-align:left;
  }
  .trophy-row{
    display:flex; justify-content:space-between; font-family:'IBM Plex Mono', monospace;
    font-size:12px; color:#B9B9AB; padding:7px 0; border-bottom:1px solid #26261F;
  }
  .trophy-row:last-child{ border-bottom:none; }
  .trophy-row b{ color:var(--trap); font-weight:500; }
  .from{ font-family:'IBM Plex Mono', monospace; font-size:12px; color:#8C8C7A; margin-bottom:22px; }
  .again{
    background:none; border:1px solid #3A3A32; color:#B9B9AB; font-family:'IBM Plex Mono', monospace;
    font-size:12px; padding:10px 18px; border-radius:100px; cursor:pointer; transition:border-color .2s, color .2s;
  }
  .again:hover{ border-color:var(--trap); color:var(--trap); }

  @media (prefers-reduced-motion: reduce){
    #btn{ transition:background .18s, border-color .18s; }
    .stage{ transition:none; }
  }
</style>
</head>
<body>

<div class="stage" id="stage">

  <!-- STAGE 1: dodge button -->
  <div class="screen active" id="s-button">
    <h1>One click.</h1>
    <p class="sub">That's it. Promise.</p>
    <div class="zone" id="zone"><button id="btn">Click me</button></div>
  </div>

  <!-- STAGE 2: robot check -->
  <div class="screen" id="s-robot">
    <div class="eyebrow">Security check</div>
    <h1>Are you human?</h1>
    <p class="sub">Just a formality. Takes a second.</p>
    <label class="check-row" id="robotRow">
      <input type="checkbox" id="robotCheck" />
      <span>I am not a robot</span>
    </label>
    <div class="fail-toast" id="robotToast"></div>
  </div>

  <!-- STAGE 3: slider -->
  <div class="screen" id="s-slider">
    <div class="eyebrow">Next formality</div>
    <h1>Drag all the way right.</h1>
    <p class="sub" id="sliderSub">All. The. Way.</p>
    <div class="slider-wrap">
      <input type="range" id="slider" min="0" max="100" value="0" />
      <div class="slider-labels"><span>START</span><span>END</span></div>
    </div>
  </div>

  <!-- STAGE 4: loading -->
  <div class="screen" id="s-loading">
    <div class="eyebrow">Almost there</div>
    <h1 id="loadTitle">Processing …</h1>
    <p class="sub" id="loadSub">Please don't close this.</p>
    <div class="bar-track"><div class="bar-fill" id="barFill"></div></div>
    <div class="bar-pct" id="barPct">0%</div>
  </div>

  <!-- STAGE 5: terms -->
  <div class="screen" id="s-terms">
    <div class="eyebrow">Last step</div>
    <h1>Almost unbearable, isn't it?</h1>
    <div class="terms-box">
      <p>§1 — There's nothing to win. There never was.</p>
      <p>§2 — You knew that by stage one, darling.</p>
      <p>§3 — You kept going anyway.</p>
      <p>§4 — We respect that. A little bit.</p>
      <p>§5 — By clicking "Finally get it over with" you agree that this time is gone. For good.</p>
    </div>
    <label class="terms-check">
      <input type="checkbox" id="termsCheck" />
      <span>Read it. Understood nothing. Don't care.</span>
    </label>
    <div style="height:16px"></div>
    <button class="primary" id="termsBtn" disabled>Finally get it over with</button>
  </div>

  <!-- WIN -->
  <div class="screen" id="s-win">
    <h2>Gotcha, darling.</h2>
    <p class="lead">One click, you thought. That was <span id="winTime">--</span> ago.</p>
    <div class="trophy" id="trophy"></div>
    <div class="from">— with love, <span id="fromName">someone who knows you far too well</span></div>
    <button class="again" id="again">Fall for it again</button>
  </div>

  <div class="narrator"><span id="narrator"></span></div>
</div>

<script>
(function(){
  var FROM_NAME = ""; // put the sender's name here

  var stageEl = document.getElementById('stage');
  var narrator = document.getElementById('narrator');
  var startTime = Date.now();

  var stats = { dodges:0, robotFails:0, sliderSnaps:0, loadingResets:0 };

  function say(text){ narrator.textContent = text; }

  function showScreen(id){
    document.querySelectorAll('.screen').forEach(function(s){ s.classList.remove('active'); });
    document.getElementById(id).classList.add('active');
  }

  /* ---------- STAGE 1: dodging button ---------- */
  var zone = document.getElementById('zone');
  var btn = document.getElementById('btn');
  var MAX_DODGES = 7;
  var dodgeCount = 0;

  var taunts = ["Click me","Oh darling.","Try harder.","Nice try, sweetie.","Aw, so close.","You're too slow.","...ok fine, here."];
  var dodgeLines = [
    "One click, you said.",
    "Oh honey. You actually believed that.",
    "The button has trust issues. With you specifically.",
    "You might need to get faster, darling.",
    "But here you are. Still.",
    "Kinda impressive. Kinda sad. Keep going.",
    "Ok, last try. Promise. (Lying again, darling.)"
  ];

  function rand(min,max){ return Math.random()*(max-min)+min; }

  function dodge(){
    dodgeCount++;
    stats.dodges++;
    btn.textContent = taunts[Math.min(dodgeCount-1, taunts.length-1)];
    say(dodgeLines[Math.min(dodgeCount-1, dodgeLines.length-1)]);
    var zw=zone.clientWidth, zh=zone.clientHeight, bw=btn.offsetWidth, bh=btn.offsetHeight;
    var padX=bw/2+6, padY=bh/2+6;
    btn.style.left = rand(padX, Math.max(padX+1, zw-padX)) + "px";
    btn.style.top = rand(padY, Math.max(padY+1, zh-padY)) + "px";
    if (dodgeCount >= MAX_DODGES) btn.classList.add('armed');
  }

  btn.addEventListener('pointerenter', function(){ if (dodgeCount < MAX_DODGES) dodge(); });
  btn.addEventListener('touchstart', function(e){ if (dodgeCount < MAX_DODGES){ e.preventDefault(); dodge(); } }, {passive:false});
  btn.addEventListener('click', function(e){
    if (dodgeCount < MAX_DODGES){ e.preventDefault(); dodge(); return; }
    say("Oh. That was easier than expected. Too easy.");
    setTimeout(function(){ showScreen('s-robot'); say("Formality number one, darling."); }, 500);
  });

  /* ---------- STAGE 2: robot checkbox ---------- */
  var robotCheck = document.getElementById('robotCheck');
  var robotToast = document.getElementById('robotToast');
  var robotFailMsgs = [
    "Error: too human for a robot, too slow for a human.",
    "Error: suspected sarcasm. Charming, but no.",
    "Error: the checkbox is simply not that into you yet.",
    "Error: you hesitated. Bots don't hesitate, darling."
  ];
  var ROBOT_FAILS_NEEDED = 3;

  robotCheck.addEventListener('change', function(){
    if (!robotCheck.checked) return;
    if (stats.robotFails < ROBOT_FAILS_NEEDED){
      stats.robotFails++;
      robotToast.textContent = robotFailMsgs[stats.robotFails-1];
      say("Oh darling, formality number one is dragging, isn't it?");
      setTimeout(function(){ robotCheck.checked = false; }, 260);
      return;
    }
    robotToast.textContent = "Confirmed. Reluctantly.";
    say("Fine. You earned that one. Formality two, love.");
    setTimeout(function(){ showScreen('s-slider'); }, 550);
  });

  /* ---------- STAGE 3: slider ---------- */
  var slider = document.getElementById('slider');
  var sliderSub = document.getElementById('sliderSub');
  var SLIDER_SNAPS_NEEDED = 2;
  var sliderSubLines = [
    "All. The. Way.",
    "Oh sweetie, all the way. That means further.",
    "The server got distracted, darling. Once more."
  ];

  slider.addEventListener('change', function(){
    var v = Number(slider.value);
    if (v < 100){ slider.value = 0; return; }
    if (stats.sliderSnaps < SLIDER_SNAPS_NEEDED){
      stats.sliderSnaps++;
      sliderSub.textContent = sliderSubLines[Math.min(stats.sliderSnaps, sliderSubLines.length-1)];
      say("That worked. Do it again anyway, darling.");
      slider.value = 0;
      return;
    }
    say("It actually worked. How shocking.");
    setTimeout(function(){ showScreen('s-loading'); startLoading(); }, 400);
  });

  /* ---------- STAGE 4: fake loading ---------- */
  var barFill = document.getElementById('barFill');
  var barPct = document.getElementById('barPct');
  var loadTitle = document.getElementById('loadTitle');
  var loadSub = document.getElementById('loadSub');
  var LOADING_RESETS_NEEDED = 2;

  function animateBar(to, duration, cb){
    var start = parseFloat(barFill.style.width) || 0;
    var t0 = performance.now();
    function step(t){
      var p = Math.min(1, (t - t0) / duration);
      var val = start + (to - start) * p;
      barFill.style.width = val + "%";
      barPct.textContent = Math.round(val) + "%";
      if (p < 1) requestAnimationFrame(step); else if (cb) cb();
    }
    requestAnimationFrame(step);
  }

  function loadingRound(){
    loadTitle.textContent = "Processing …";
    loadSub.textContent = stats.loadingResets === 0 ? "Please don't close this, darling." : "This time for real.";
    animateBar(98, 900, function(){
      setTimeout(function(){
        if (stats.loadingResets < LOADING_RESETS_NEEDED){
          stats.loadingResets++;
          loadTitle.textContent = stats.loadingResets === 1 ? "Oh honey. The server has doubts." : "The server doubts you again.";
          loadSub.textContent = stats.loadingResets === 1 ? "Recalculating." : "This is embarrassing for both of us.";
          say(stats.loadingResets === 1 ? "98%. And back to zero. Classic, darling." : "Are you f***ing serious right now.");
          barFill.style.transition = "none";
          barFill.style.width = "4%"; barPct.textContent = "4%";
          void barFill.offsetWidth;
          barFill.style.transition = "width .5s var(--ease)";
          setTimeout(loadingRound, 500);
        } else {
          animateBar(100, 300, function(){
            say("Done. Really. Almost, darling.");
            setTimeout(function(){ showScreen('s-terms'); }, 500);
          });
        }
      }, 400);
    });
  }
  function startLoading(){
    barFill.style.width = "0%"; barPct.textContent = "0%";
    say("Last formality. Probably.");
    loadingRound();
  }

  /* ---------- STAGE 5: terms ---------- */
  var termsCheck = document.getElementById('termsCheck');
  var termsBtn = document.getElementById('termsBtn');
  termsCheck.addEventListener('change', function(){
    termsBtn.disabled = !termsCheck.checked;
    if (termsCheck.checked){
      termsBtn.classList.add('hot');
      say("Last click, darling. This time for real. (Not really.)");
    } else {
      termsBtn.classList.remove('hot');
    }
  });
  termsBtn.addEventListener('click', function(){ win(); });

  /* ---------- WIN ---------- */
  function fmtTime(ms){
    var s = Math.round(ms/1000);
    if (s < 60) return s + " seconds";
    var m = Math.floor(s/60), r = s%60;
    return m + " min " + r + " sec";
  }

  function win(){
    var elapsed = Date.now() - startTime;
    document.getElementById('winTime').textContent = fmtTime(elapsed);
    if (FROM_NAME) document.getElementById('fromName').textContent = FROM_NAME;
    var trophy = document.getElementById('trophy');
    trophy.innerHTML =
      '<div class="trophy-row"><span>Time invested</span><b>' + fmtTime(elapsed) + '</b></div>' +
      '<div class="trophy-row"><span>Times you got dodged</span><b>' + stats.dodges + 'x</b></div>' +
      '<div class="trophy-row"><span>Mistaken for a robot</span><b>' + stats.robotFails + 'x</b></div>' +
      '<div class="trophy-row"><span>Slider reset on you</span><b>' + stats.sliderSnaps + 'x</b></div>' +
      '<div class="trophy-row"><span>Progress bar lied</span><b>' + stats.loadingResets + 'x</b></div>' +
      '<div class="trophy-row"><span>Prize won</span><b>None, darling</b></div>';
    say("");
    stageEl.classList.add('won');
  }

  document.getElementById('again').addEventListener('click', function(){
    stageEl.classList.remove('won');
    dodgeCount = 0; stats = { dodges:0, robotFails:0, sliderSnaps:0, loadingResets:0 };
    btn.classList.remove('armed'); btn.textContent = "Click me";
    btn.style.left = "50%"; btn.style.top = "50%";
    robotCheck.checked = false; robotToast.textContent = "";
    slider.value = 0; sliderSub.textContent = sliderSubLines[0];
    termsCheck.checked = false; termsBtn.disabled = true; termsBtn.classList.remove('hot');
    startTime = Date.now();
    showScreen('s-button');
    say("");
  });

  say("Just one click. Easy.");
})();
</script>

</body>
</html>
